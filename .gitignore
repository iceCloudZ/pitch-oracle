# Dependencies
node_modules/

# Build outputs
dist/
build/
.svelte-kit/
.vercel/
.output/

# Env / secrets (API keys live here — never commit)
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.swp

# Test coverage
coverage/

# Local data overrides (generated state is committed to the `data` branch in CI)
data/local/

# Dashboard: synced JSON under static/data/ is a build artifact (copied from
# repo-root data/ by scripts/sync-data.mjs). Keep the README + .gitkeep only.
dashboard/static/data/*
!dashboard/static/data/README.md
!dashboard/static/data/.gitkeep
